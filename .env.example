# --- Development (.env.development) ---
# Vite proxies /api/* to this URL during local dev (avoids CORS)
VITE_PROXY_TARGET=http://localhost:8080
# Keep empty in dev — requests go through the proxy above
VITE_API_URL=

# --- Production (.env.production) ---
# Direct backend URL used in the built bundle
# VITE_API_URL=https://adnexx-backend-production.up.railway.app

