# ============================================================
# Environment variable reference — copy to .env / .env.development / .env.production
# ============================================================

# Backend URL that the Vite dev server proxies /api/* to (local dev only)
# VITE_PROXY_TARGET=http://localhost:8080
VITE_PROXY_TARGET=http://ec2-65-0-102-18.ap-south-1.compute.amazonaws.com:8080

# Base URL for browser API calls.
#   dev  → leave EMPTY (proxy handles it, avoids CORS)
#   prod → set to full backend URL
VITE_API_URL=

# Vite dev server port (default: 3020)
VITE_PORT=3020

# Health check path appended to VITE_PROXY_TARGET for /api/ping
VITE_HEALTH_PATH=/api/v1/actuator/health

