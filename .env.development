# Development environment
# Vite proxies all /api/* requests to this target (avoids CORS in local dev)
# Change to http://localhost:8080 when running backend locally
VITE_PROXY_TARGET=http://localhost:8080

# Leave EMPTY — browser calls /api/* which is proxied by Vite above (no CORS)
VITE_API_URL=

# Dev server port
VITE_PORT=3020

# Health check path used by /api/ping
VITE_HEALTH_PATH=/api/v1/actuator/health
